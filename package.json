{
  "name": "linz-address-import",
  "version": "3.0.0",
  "author": "Kyle Hensel",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "download-linz": "tsx --env-file-if-exists=.env src/download/downloadLinzExport",
    "preprocess1": "tsx src/cli --steps=download",
    "preprocess2": "tsx src/preprocess/processLinzData",
    "preprocess3": "tsx src/preprocess/stackLinzData",
    "preprocess": "npm run preprocess1 && npm run preprocess2 && npm run preprocess3",
    "match": "tsx --max-old-space-size=8192 src/cli --steps=match",
    "conflate": "tsx --max-old-space-size=8192 src/cli --steps=conflate",
    "changesetWatch": "tsx src/changesetWatch",
    "lint": "eslint . && tsc",
    "test": "vitest",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@id-sdk/geo": "^3.0.0-pre.10",
    "@osm-conflation-engine/changeset-watcher": "^3.1.1",
    "@osm-conflation-engine/cli": "^3.2.0",
    "csv-parser": "^3.2.1",
    "h3-js": "^4.4.0",
    "osm-api": "^4.0.0"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-kyle": "^29.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "prettier": "eslint-config-kyle/prettier",
  "engineStrict": true,
  "engines": {
    "node": ">=v26"
  }
}
